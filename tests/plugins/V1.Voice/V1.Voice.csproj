<Project Sdk="Microsoft.NET.Sdk">

  <!-- 测试插件（V1 / voice）。引用当前 V1 SDK，Private=false 不打进包。输出落 tests/packages/v1-voice/。 -->
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <OutputPath>$(MSBuildThisFileDirectory)..\..\packages\v1-voice\</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <AppendRuntimeIdentifierToOutputPath>false</AppendRuntimeIdentifierToOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\TuneLab.Foundation\TuneLab.Foundation.csproj" Private="false" />
    <ProjectReference Include="..\..\..\TuneLab.SDK\TuneLab.SDK.csproj" Private="false" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="manifest.json" CopyToOutputDirectory="PreserveNewest" />
    <!-- 立绘资源（随包发布，引擎按包目录拼绝对路径喂 FileImageResource）：静态 webp + 动态 webp 各一。 -->
    <Content Include="portrait.webp" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="portrait-anim.webp" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
