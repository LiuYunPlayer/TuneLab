<Project Sdk="Microsoft.NET.Sdk">

  <!-- 一包多插件之 voice 入口。与同包 format 共享 V1.Suite.Common（只分发一份、同 ALC 只加载一份）。
       输出同落 packages/v1-suite/，与 format 入口同处一个包/ALC。 -->
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <OutputPath>$(MSBuildThisFileDirectory)..\..\packages\v1-suite\</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <AppendRuntimeIdentifierToOutputPath>false</AppendRuntimeIdentifierToOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\TuneLab.Foundation\TuneLab.Foundation.csproj" Private="false" />
    <ProjectReference Include="..\..\..\TuneLab.SDK\TuneLab.SDK.csproj" Private="false" />
    <ProjectReference Include="..\V1.Suite.Common\V1.Suite.Common.csproj" />
  </ItemGroup>

</Project>
