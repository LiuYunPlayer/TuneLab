{
  "id": "com.tunelab.test.v1suite",
  "name": "V1 Test Suite",
  "version": "1.0.0",
  "author": "TuneLab Tests",
  "description": "一包多插件：format + voice 共享 V1.Suite.Common.dll（只分发一份、同 ALC 只加载一份）。",
  "sdk-version": "1.0",
  "extensions": [
    {
      "type": "format",
      "extension": "tlsuite",
      "name": "Suite Format",
      "import": "TuneLab.TestPlugins.Suite.Format.SuiteImportFormat",
      "export": "TuneLab.TestPlugins.Suite.Format.SuiteExportFormat",
      "assembly": "V1.Suite.Format.dll"
    },
    {
      "type": "voice",
      "engine": "TLSuiteVoice",
      "name": "Suite Voice",
      "class": "TuneLab.TestPlugins.Suite.Voice.SuiteVoiceEngine",
      "assembly": "V1.Suite.Voice.dll"
    }
  ]
}
