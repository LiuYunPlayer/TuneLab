<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="720"
        x:Class="TuneLab.UI.SettingsWindow"
        Title="Settings - TuneLab"
		Width="800"
		Height="720"
		ExtendClientAreaChromeHints="NoChrome"
		ExtendClientAreaTitleBarHeightHint="40"
		ExtendClientAreaToDecorationsHint="True">
	
	<DockPanel>
		<Grid DockPanel.Dock="Top" Height="40" x:Name="TitleBar">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>
			
			<StackPanel Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Horizontal" IsHitTestVisible="False"/>
			<StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Horizontal" IsHitTestVisible="False">
				<Label Content="Settings" x:Name="TitleLabel" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" BorderThickness="0" IsHitTestVisible="False"/>
			</StackPanel>
			<StackPanel Grid.Column="2" x:Name="WindowControl" HorizontalAlignment="Right" VerticalAlignment="Center" />
		</Grid>

		<Grid x:Name="MainGrid">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="220"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>
			
			<!-- Left Sidebar -->
			<Border Grid.Column="0" x:Name="SidebarBorder">
				<StackPanel x:Name="SidebarPanel" Orientation="Vertical" Margin="0,8,0,0"/>
			</Border>
			
			<!-- Right Content Area -->
			<Border Grid.Column="1" x:Name="ContentBorder">
				<DockPanel x:Name="ContentPanel"/>
			</Border>
		</Grid>
	</DockPanel>
</Window>
